[user]
  name = YOUR_NAME
  email = YOUR_EMAIL

[core]
  editor = nvim
  excludesfile = ~/.gitignore
  pager = diff-so-fancy | less --tabs=4 -RFX
  whitespace = space-before-tab,-indent-with-non-tab,trailing-space
  trustctime = false
  precomposeunicode = false

[interactive]
  diffFilter = diff-so-fancy --patch

[color]
  ui = true
  diff = auto
  status = auto
  branch = auto
  interactive = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow
  frag = magenta bold
  old = red bold
  new = green bold
  commit = yellow bold
  whitespace = red reverse

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[branch]
  autosetuprebase = always

[push]
  default = current
  followTags = true

[pull]
  rebase = true

[rebase]
  autoStash = true

[help]
  autocorrect = 1

[alias]
  # Status
  s = status -s

  # Log
  lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  l = log --oneline --graph --decorate
  last = log -1 HEAD

  # Diff
  d = diff
  dc = diff --cached

  # Checkout / branch
  co = checkout
  br = branch
  go = "!f() { git checkout -b \"$1\" 2> /dev/null || git checkout \"$1\"; }; f"

  # Commit
  ci = commit
  amend = commit --amend --reuse-message=HEAD
  commend = commit --amend --no-edit

  # Push
  please = push --force-with-lease

  # Rebase
  reb = "!r() { git rebase -i HEAD~$1; }; r"

  # Branch cleanup — delete all merged branches except main/master/develop
  dm = "!git branch --merged | grep -Ev '(^\\*|main|master|develop)' | xargs -r git branch -d"

  # Stash
  stsh = stash --keep-index
  staash = stash --include-untracked

  # Clone
  cl = clone --recursive

  # Fuzzy branch checkout (requires fzf)
  b = "!BRANCH=$(git branch | fzf) && git checkout $BRANCH"

  # Find branches/tags/commits containing a commit
  fb = "!f() { git branch -a --contains $1; }; f"
  ft = "!f() { git describe --always --contains $1; }; f"
  fc = "!f() { git log --pretty=format:'%C(yellow)%h  %Cblue%ad  %Creset%s%Cgreen  [%cn] %Cred%d' --decorate --date=short -S$1; }; f"

[commit]
  template = ~/.git-commit-template

[url "git@github.com:"]
  insteadOf = gh:

[init]
  defaultBranch = main
